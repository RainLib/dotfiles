{{ if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
#!/bin/sh
set -eu

if [ "${TMUX_PLUGIN_INSTALL_ON_APPLY:-1}" = "0" ]; then
  echo "Skipping tmux plugin install."
  exit 0
fi

TPM_DIR="$HOME/.tmux/plugins/tpm"
CATPPUCCIN_TMUX_DIR="$HOME/.tmux/plugins/tmux"
VIM_TMUX_NAVIGATOR_DIR="$HOME/.tmux/plugins/vim-tmux-navigator"

if ! command -v git >/dev/null 2>&1; then
  echo "git is required to install tmux plugins." >&2
  exit 1
fi

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is not on PATH; skipping tmux plugin install." >&2
  exit 0
fi

if [ ! -d "$TPM_DIR/.git" ]; then
  mkdir -p "$(dirname "$TPM_DIR")"
  git clone https://github.com/tmux-plugins/tpm "$TPM_DIR"
fi

if [ ! -d "$CATPPUCCIN_TMUX_DIR/.git" ]; then
  git clone https://github.com/catppuccin/tmux.git "$CATPPUCCIN_TMUX_DIR"
fi

if [ ! -d "$VIM_TMUX_NAVIGATOR_DIR/.git" ]; then
  git clone https://github.com/christoomey/vim-tmux-navigator.git "$VIM_TMUX_NAVIGATOR_DIR"
fi

if tmux has-session >/dev/null 2>&1 && [ -f "$HOME/.tmux.conf" ]; then
  tmux source-file "$HOME/.tmux.conf"
fi
{{ end -}}
