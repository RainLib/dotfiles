}

dsh() {
  emulate -L zsh
  local container shell

  _dotfiles_need_command docker || return
  _dotfiles_need_command fzf || return
  container=$(docker ps --format '{{.Names}}' | fzf --prompt='container> ') || return
  for shell in bash zsh sh; do
    if docker exec "$container" command -v "$shell" >/dev/null 2>&1; then
      docker exec -it "$container" "$shell"
      return
    fi
  done
}

