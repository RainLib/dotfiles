# hh - show all loaded aliases in a readable list.
hh() {
  emulate -L zsh
  local name
  local -a pager

  if (( ${#aliases} == 0 )); then
    print "No aliases are currently loaded"
    return 0
  fi

  if [[ -t 1 ]] && (( $+commands[less] )); then
    pager=(less -F -R -X)
  else
    pager=(cat)
  fi

  {
    printf '%-18s %s\n' "Alias" "Command"
    printf '%-18s %s\n' "-----" "-------"
    for name in ${(ok)aliases}; do
      printf '%-18s %s\n' "$name" "$aliases[$name]"
    done
  } | "${pager[@]}"
}

_dotfiles_need_command() {
  command -v "$1" >/dev/null 2>&1 || {
    print -u2 "$1 is not installed or not on PATH"
    return 127
  }
}

jdk() {
  emulate -L zsh
  local version="${1:-${DOTFILES_JAVA_VERSION:-17}}"
  local java_home

  if [[ ! -x /usr/libexec/java_home ]]; then
    print -u2 "/usr/libexec/java_home is not available"
    return 127
  fi

  java_home=$(/usr/libexec/java_home -v "$version" 2>/dev/null) || {
    print -u2 "No JDK found for version: $version"
    /usr/libexec/java_home -V 2>&1
    return 1
  }

  [[ -n "$JAVA_HOME" ]] && path=("${(@)path:#$JAVA_HOME/bin}")
  export JAVA_HOME="$java_home"
  path=("$JAVA_HOME/bin" "${path[@]}")
  export PATH
  java -version
}

_dotfiles_init_java() {
  [[ -x /usr/libexec/java_home ]] || return 0
  jdk "${DOTFILES_JAVA_VERSION:-17}" >/dev/null 2>&1 || jdk 1.8 >/dev/null 2>&1 || true
}

