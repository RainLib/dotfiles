proj() {
  emulate -L zsh
  local root="${1:-$HOME/project}"
  local target

  _dotfiles_need_command fzf || return
  target=$(find "$root" -mindepth 1 -maxdepth 4 -type d -name .git -prune -print 2>/dev/null |
    \sed 's#/.git$##' |
    fzf --prompt='project> ') || return
  cd "$target"
}

gclean() {
  emulate -L zsh
  local main="${1:-main}"
  local branch

  git fetch --prune
  git branch --merged "$main" |
    \sed 's/^[* ]*//' |
    \grep -vE "^(${main}|master|develop)$" |
    while read -r branch; do
      [[ -n "$branch" ]] && git branch -d "$branch"
    done
}

gsw-fzf() {
  emulate -L zsh
  local branch

  _dotfiles_need_command fzf || return
  branch=$(git branch --all --format='%(refname:short)' |
    \sed 's#^origin/##' |
    \sort -u |
    fzf --prompt='branch> ') || return
  git switch "$branch"
}

dcu() {
