killport() {
  emulate -L zsh
  local signal="TERM"
  local assume_yes=0
  local port reply
  local -a pids

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -9|--force)
        signal="KILL"
        shift
        ;;
      -y|--yes)
        assume_yes=1
        shift
        ;;
      -h|--help)
        print "usage: killport [-9|--force] [-y|--yes] <port> [port...]"
        return 0
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    print -u2 "usage: killport [-9|--force] [-y|--yes] <port> [port...]"
    return 2
  fi

  for port in "$@"; do
    if [[ "$port" != <-> ]]; then
      print -u2 "invalid port: $port"
      continue
    fi

    pids=(${(f)"$(\lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null | \sort -u)"})
    if (( ${#pids} == 0 )); then
      print "No process is listening on port $port"
      continue
    fi

    \lsof -nP -iTCP:"$port" -sTCP:LISTEN
    if (( ! assume_yes )); then
      print -n "Kill ${#pids} process(es) on port $port with SIG$signal? [y/N] "
      read -r reply
      [[ "$reply" == [Yy]* ]] || {
        print "Skipped port $port"
        continue
      }
    fi

    \kill "-$signal" -- "${pids[@]}"
  done
}

psgrep() {
  if [[ $# -eq 0 ]]; then
    print -u2 "usage: psgrep <pattern>"
    return 2
  fi
  \ps axo pid,ppid,stat,command | \grep -i -- "$*" | \grep -v '[g]rep'
}

killname() {
  emulate -L zsh
  local signal="TERM"
  local assume_yes=0
  local pattern reply
  local -a pids

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -9|--force)
        signal="KILL"
        shift
        ;;
      -y|--yes)
        assume_yes=1
        shift
        ;;
      -h|--help)
        print "usage: killname [-9|--force] [-y|--yes] <pattern>"
        return 0
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    print -u2 "usage: killname [-9|--force] [-y|--yes] <pattern>"
    return 2
  fi

  pattern="$*"
  pids=(${(f)"$(\pgrep -if -- "$pattern" 2>/dev/null | \sort -u)"})
  pids=("${(@)pids:#$$}")

  if (( ${#pids} == 0 )); then
    print "No process matched: $pattern"
    return 1
  fi

  \ps -p "${(j:,:)pids}" -o pid,ppid,stat,command
  if (( ! assume_yes )); then
    print -n "Kill ${#pids} matched process(es) with SIG$signal? [y/N] "
    read -r reply
    [[ "$reply" == [Yy]* ]] || {
      print "Skipped"
      return 1
    }
  fi

  \kill "-$signal" -- "${pids[@]}"
}

