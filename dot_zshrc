# Ctrl-x a opens an fzf picker and inserts the selected alias name.
_dotfiles_insert_alias() {
  emulate -L zsh
  local selected alias_name

  if (( ${#aliases} == 0 )); then
    zle -M "No aliases are currently loaded"
    return 1
  fi

  if (( ! $+commands[fzf] )); then
    zle -M "fzf is required to pick aliases"
    return 1
  fi

  selected=$(
    {
      local name
      for name in ${(ok)aliases}; do
        printf '%s=%s\n' "$name" "$aliases[$name]"
      done
    } | fzf --height=40% --reverse --prompt="alias> " --delimiter="=" --with-nth=1,2
  ) || return 0

  alias_name="${selected%%=*}"
  [ -n "$alias_name" ] || return 0

  LBUFFER+="$alias_name "
  zle redisplay
}

if [[ -o interactive ]]; then
  zle -N dotfiles-insert-alias _dotfiles_insert_alias
  bindkey '^Xa' dotfiles-insert-alias
  for keymap in emacs viins vicmd; do
    bindkey -M "$keymap" '^Xa' dotfiles-insert-alias 2>/dev/null || true
  done
fi

# cdf - cd to selected directory
cdf() {
  local dir
  if command -v fd >/dev/null 2>&1; then
    dir=$(command fd -H -t d . "${1:-.}" --max-depth 8 | fzf +m)
  else
    dir=$(find ${1:-.} -path '*/\.*' -prune \
                    -o -type d -print 2> /dev/null | fzf +m)
  fi
  [[ -n "$dir" ]] &&
  cd "$dir"
}

# fh - search in your command history and execute selected command
fh() {
  eval $( ([ -n "$ZSH_NAME" ] && fc -l 1 || history) | fzf +s --tac | sed 's/ *[0-9]* *//')
}

